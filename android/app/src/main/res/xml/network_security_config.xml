<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- السماح بالاتصال بجميع النطاقات (للإنتاج، قم بتحديد النطاقات المحددة فقط) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust preinstalled CAs -->
            <certificates src="system" />
            <!-- Additionally trust user added CAs -->
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    
    <!-- إعدادات خاصة للنطاق crystal4card.com -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">crystal4card.com</domain>
        <domain includeSubdomains="true">www.crystal4card.com</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
    
    <!-- للاختبار المحلي (localhost) - يمكن حذفه في الإنتاج -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>
</network-security-config>
